# Copy this file to .env and fill in your values

# Port the server listens on (default: 5005)
PORT=5005

# Path to the data directory (default: ../data relative to backend/)
# DATA_DIR=/absolute/path/to/data

# Flask debug mode (default: 0 — use 1 for local development only)
FLASK_DEBUG=0

# Ollama LLM for MIRA assistant (optional)
LLM_PROVIDER=ollama
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
